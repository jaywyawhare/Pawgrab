PAWGRAB_HOST=0.0.0.0
PAWGRAB_PORT=8000
PAWGRAB_LOG_LEVEL=info
PAWGRAB_API_KEY=

PAWGRAB_REDIS_URL=redis://localhost:6379/0
PAWGRAB_REDIS_OPERATION_TIMEOUT=5.0

PAWGRAB_LLM_PROVIDER=openai  # openai, anthropic, gemini, ollama
PAWGRAB_OPENAI_API_KEY=
PAWGRAB_OPENAI_MODEL=gpt-4o-mini
PAWGRAB_ANTHROPIC_API_KEY=
PAWGRAB_ANTHROPIC_MODEL=claude-sonnet-4-20250514
PAWGRAB_GEMINI_API_KEY=
PAWGRAB_GEMINI_MODEL=gemini-2.0-flash
PAWGRAB_OLLAMA_BASE_URL=http://localhost:11434
PAWGRAB_OLLAMA_MODEL=llama3

PAWGRAB_BROWSER_POOL_SIZE=3
PAWGRAB_BROWSER_TYPE=chromium
PAWGRAB_BROWSER_STANDBY_RECYCLE=true
PAWGRAB_BROWSER_SESSION_PROFILES=true
PAWGRAB_BROWSER_TRACE_ENABLED=false

PAWGRAB_RATE_LIMIT_RPM=60
PAWGRAB_API_RATE_LIMIT_RPM=600

PAWGRAB_RESPECT_ROBOTS=true
PAWGRAB_ROBOTS_CACHE_TTL=3600
PAWGRAB_ROBOTS_FETCH_TIMEOUT=10

PAWGRAB_STEALTH_MODE=true
PAWGRAB_MAX_CHALLENGE_RETRIES=2
PAWGRAB_IMPERSONATE=
PAWGRAB_SOLVE_CLOUDFLARE=true

PAWGRAB_CAPTCHA_PROVIDER=  # "2captcha" or "capsolver"
PAWGRAB_CAPTCHA_API_KEY=

PAWGRAB_PROXY_URL=
PAWGRAB_PROXY_URLS=
PAWGRAB_PROXY_ROTATION_POLICY=round_robin
PAWGRAB_PROXY_HEALTH_CHECK=true
PAWGRAB_PROXY_HEALTH_CHECK_INTERVAL=300

PAWGRAB_SEARCH_PROVIDER=duckduckgo
PAWGRAB_SERPAPI_KEY=
PAWGRAB_GOOGLE_SEARCH_API_KEY=
PAWGRAB_GOOGLE_SEARCH_CX=

PAWGRAB_WEBHOOK_TIMEOUT=15
PAWGRAB_WEBHOOK_RETRIES=3

PAWGRAB_SITEMAP_FETCH_TIMEOUT=15

PAWGRAB_WORKER_MAX_JOBS=5
PAWGRAB_WORKER_JOB_TIMEOUT=600
PAWGRAB_CHECKPOINT_INTERVAL=10

PAWGRAB_SSE_MAX_DURATION=3600
PAWGRAB_MAX_TIMEOUT=120000

PAWGRAB_CACHE_TTL=0  # 0 = disabled

PAWGRAB_MEMORY_THRESHOLD_PERCENT=85.0
PAWGRAB_MIN_CONCURRENCY=1
PAWGRAB_MAX_CONCURRENCY=10

PAWGRAB_PLUGINS=

PAWGRAB_STORAGE_BACKEND=  # filesystem, s3
PAWGRAB_STORAGE_PATH=./pawgrab_data
PAWGRAB_S3_BUCKET=
PAWGRAB_S3_PREFIX=pawgrab
PAWGRAB_S3_REGION=us-east-1
PAWGRAB_S3_ENDPOINT_URL=
PAWGRAB_S3_ACCESS_KEY=
PAWGRAB_S3_SECRET_KEY=
