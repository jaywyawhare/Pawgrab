# Pawgrab Configuration
# Copy to .env and fill in values

# API settings
PAWGRAB_HOST=0.0.0.0
PAWGRAB_PORT=8000
PAWGRAB_LOG_LEVEL=info

# Authentication (leave empty to disable)
PAWGRAB_API_KEY=

# Redis (required for /crawl queue)
PAWGRAB_REDIS_URL=redis://localhost:6379/0

# OpenAI (required for /extract)
PAWGRAB_OPENAI_API_KEY=sk-...
PAWGRAB_OPENAI_MODEL=gpt-4o-mini

# Browser settings
PAWGRAB_BROWSER_POOL_SIZE=3
PAWGRAB_BROWSER_TIMEOUT=30000

# Rate limiting
PAWGRAB_RATE_LIMIT_RPM=60

# Robots.txt
PAWGRAB_RESPECT_ROBOTS=true

# Anti-bot / stealth
PAWGRAB_STEALTH_MODE=true
PAWGRAB_MAX_CHALLENGE_RETRIES=2
PAWGRAB_IMPERSONATE=           # curl_cffi target (e.g. safari184). Empty = random per request

# Proxy (e.g. http://user:pass@proxy:8080)
PAWGRAB_PROXY_URL=
# Multiple proxies for rotation on retries (comma-separated)
PAWGRAB_PROXY_URLS=

# Safety limits
PAWGRAB_MAX_TIMEOUT=120000
PAWGRAB_MAX_CRAWL_PAGES=500
PAWGRAB_MAX_CRAWL_DEPTH=10

# Response caching (seconds, 0 = disabled)
PAWGRAB_CACHE_TTL=0
